# ══════════════════════════════════════════════════════════════════════
#  /etc/salonpro-api/env  — NUNCA subir al repositorio
#  Copiar este archivo al servidor como:
#    sudo cp deploy/env.example /etc/salonpro-api/env
#    sudo chmod 600 /etc/salonpro-api/env
#    sudo nano /etc/salonpro-api/env   (editar con valores reales)
# ══════════════════════════════════════════════════════════════════════

# Connection string SQL Server (Linux, SQL auth)
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=SalonProDb;User Id=salonpro_app;Password=CAMBIA_ESTO;TrustServerCertificate=true;

# JWT — string aleatorio, mínimo 48 caracteres
# Genera uno con: openssl rand -base64 48
Jwt__Secret=CAMBIA_ESTO_POR_UN_STRING_ALEATORIO_DE_48_CHARS_MINIMO

# (Opcional) Serilog a archivo en producción
# Serilog__WriteTo__0__Name=File
# Serilog__WriteTo__0__Args__path=/var/log/salonpro/api-.log
# Serilog__WriteTo__0__Args__rollingInterval=Day
