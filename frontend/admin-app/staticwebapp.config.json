{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/**",
      "/*.{css,js,ico,png,svg,webp,woff,woff2,json,txt}"
    ]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
